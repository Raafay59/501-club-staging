#!/usr/bin/env bash
set -euo pipefail

PG_BIN="${PG_BIN:-/c/Users/${USERNAME:-$USER}/pgsql/pgsql/bin}"
PG_DATA="${PG_DATA:-/c/Users/${USERNAME:-$USER}/pgsql/devdata_utf8}"

if [[ ! -x "$PG_BIN/pg_ctl" ]]; then
  echo "pg_ctl not found in PG_BIN=$PG_BIN"
  echo "Set PG_BIN to your postgres bin directory and try again."
  exit 1
fi

if "$PG_BIN/pg_ctl" -D "$PG_DATA" status >/dev/null 2>&1; then
  "$PG_BIN/pg_ctl" -D "$PG_DATA" stop
  echo "Postgres stopped."
else
  echo "Postgres is not running for data dir: $PG_DATA"
fi
