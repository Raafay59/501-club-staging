<h1>User Management</h1>

<h2>Add User by Email</h2>
<%= form_with(model: @new_user, url: users_path, local: true) do |form| %>
  <% if @new_user.errors.any? %>
    <div class="form-errors" role="alert">
      <ul>
        <% @new_user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row form-row--end">
    <%= context_field_tip("users.email") do %>
      <div>
        <%= form.label :email, "Email Address" %>
        <%= form.email_field :email, placeholder: "user@tamu.edu", pattern: "^[^@\\s]+@tamu\\.edu$", title: "Email must end with @tamu.edu" %>
      </div>
    <% end %>
    <%= context_field_tip("users.role_invite") do %>
      <div>
        <%= form.label :role %>
        <%= form.select :role, options_for_select([["Editor", "editor"], ["Admin", "admin"]], "editor") %>
      </div>
    <% end %>
    <div>
      <%= form.submit "Add User" %>
    </div>
  </div>
<% end %>

<hr>

<h2>Existing Users</h2>

<table class="data-table">
  <thead>
    <tr>
      <th>Email</th>
      <th>Name</th>
      <th>Current Role</th>
      <th>Change Role</th>
      <th>Remove</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= user.full_name.presence || "-" %></td>
        <td>
          <strong><%= user.role.capitalize %></strong>
          <% if user == current_admin %>
            (you)
          <% end %>
        </td>
        <td>
          <%= context_field_tip("users.role_change") do %>
            <%= form_with(model: user, url: user_path(user), method: :patch, local: true) do |form| %>
              <%= form.select :role, [["Admin", "admin"], ["Editor", "editor"], ["Unauthorized", "unauthorized"]] %>
              <%= form.submit "Update" %>
            <% end %>
          <% end %>
        </td>
        <td>
          <% if user == current_admin %>
            -
          <% else %>
            <%= button_to "Delete", user_path(user), method: :delete, data: { turbo_confirm: "Remove #{user.email}?" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
