<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for(:title) || "TAMU Ideathon 2026" %></title>
  <meta name="description" content="Join Texas A&M's premier ideathon - 24 hours of innovation, creativity, and collaboration. February 28 - March 1, 2026.">
  
  <!-- Open Graph / Social -->
  <meta property="og:title" content="TAMU Ideathon 2026">
  <meta property="og:description" content="24 hours of innovation. $5,000+ in prizes. Join 200+ Aggies.">
  <meta property="og:type" content="website">
  
  <!-- Font Imports (Google Fonts for Titan One & Lilita One, custom for Urban Blocker) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lilita+One&family=Titan+One&display=swap" rel="stylesheet">
  
  <!-- Custom font-face for Beach Day -->
  <style>
    @font-face {
      font-family: 'Beach Day';
      src: url('/fonts/beachday.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
    
    /* Smooth scroll behavior */
    html {
      scroll-behavior: smooth;
      margin: 0;
      padding: 0;
    }
    
    body {
      margin: 0;
      padding: 0;
      background-color: rgb(255, 249, 246) !important;
    }
    
    /* Prevent scroll restoration issues */
    html:focus-within {
      scroll-behavior: smooth;
    }
    
    /* Custom scrollbar for the ideathon theme */
    ::-webkit-scrollbar {
      width: 10px;
    }
    
    ::-webkit-scrollbar-track {
      background: rgb(30, 20, 18);
    }
    
    ::-webkit-scrollbar-thumb {
      background: linear-gradient(180deg, rgb(252, 240, 228) 0%, rgb(238, 136, 138) 100%);
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: rgb(252, 240, 228);
    }
    
    /* Gradient backgrounds for decorative elements */
    .bg-gradient-radial {
      background: radial-gradient(ellipse at center, var(--tw-gradient-from) 0%, var(--tw-gradient-to) 70%);
    }
    
    /* Selection styling */
    ::selection {
      background: rgba(238, 136, 138, 0.35);
      color: white;
    }
  </style>
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <!-- Force scroll to top on page load/refresh -->
  <script>
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
    window.scrollTo(0, 0);
  </script>
  
  <%= content_for :head %>
</head>
<body class="min-h-screen font-lilita-one text-white antialiased m-0 p-0" style="background: rgb(30, 20, 18);">

  <% if flash[:alert].present? %>
    <div id="flash-notification" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 px-4 py-3 rounded-xl shadow-lg text-sm cursor-pointer select-none" style="background: rgba(220, 38, 38, 0.9); color: white !important; transition: transform 0.3s ease, opacity 0.3s ease; touch-action: pan-x;">
      <%= flash[:alert] %>
    </div>
  <% elsif flash[:success].present? %>
    <div id="flash-notification" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 px-4 py-3 rounded-xl shadow-lg text-sm cursor-pointer select-none" style="background: rgba(22, 163, 74, 0.9); color: white !important; transition: transform 0.3s ease, opacity 0.3s ease; touch-action: pan-x;">
      <%= flash[:success] %>
    </div>
  <% end %>

  <script>
    (function() {
      var el = document.getElementById('flash-notification');
      if (!el) return;

      function dismiss() {
        el.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
        el.style.transform = 'translateX(-50%) translateY(-120%)';
        el.style.opacity = '0';
        setTimeout(function() { el.remove(); }, 320);
      }

      // Auto-dismiss after 5s
      var autoTimer = setTimeout(dismiss, 5000);

      // Click to dismiss
      el.addEventListener('click', function() {
        clearTimeout(autoTimer);
        dismiss();
      });

      // Swipe up (touch)
      var touchStartY = 0;
      el.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        el.style.transition = 'none';
      }, { passive: true });

      el.addEventListener('touchmove', function(e) {
        var dy = e.touches[0].clientY - touchStartY;
        if (dy < 0) {
          el.style.transform = 'translateX(-50%) translateY(' + dy + 'px)';
          el.style.opacity = Math.max(0, 1 + dy / 80).toString();
        }
      }, { passive: true });

      el.addEventListener('touchend', function(e) {
        var dy = e.changedTouches[0].clientY - touchStartY;
        if (dy < -40) {
          clearTimeout(autoTimer);
          dismiss();
        } else {
          el.style.transition = 'transform 0.2s ease, opacity 0.2s ease';
          el.style.transform = 'translateX(-50%) translateY(0)';
          el.style.opacity = '1';
        }
      }, { passive: true });

      // Mouse drag up (desktop)
      var mouseStartY = 0, dragging = false;
      el.addEventListener('mousedown', function(e) {
        mouseStartY = e.clientY;
        dragging = true;
        el.style.transition = 'none';
      });
      document.addEventListener('mousemove', function(e) {
        if (!dragging) return;
        var dy = e.clientY - mouseStartY;
        if (dy < 0) {
          el.style.transform = 'translateX(-50%) translateY(' + dy + 'px)';
          el.style.opacity = Math.max(0, 1 + dy / 80).toString();
        }
      });
      document.addEventListener('mouseup', function(e) {
        if (!dragging) return;
        dragging = false;
        var dy = e.clientY - mouseStartY;
        if (dy < -40) {
          clearTimeout(autoTimer);
          dismiss();
        } else {
          el.style.transition = 'transform 0.2s ease, opacity 0.2s ease';
          el.style.transform = 'translateX(-50%) translateY(0)';
          el.style.opacity = '1';
        }
      });
    })();
  </script>

  <main class="m-0 p-0">
    <div class="overflow-x-hidden">
      <%= yield %>
    </div>
  </main>

  <!-- Help Modal -->
  <div id="help-modal" class="fixed inset-0 hidden items-center justify-center p-4" style="z-index: 99999; background: rgba(127, 85, 81, 0.35); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
       onclick="if(event.target===this){this.classList.add('hidden');this.classList.remove('flex');}">
    <div class="w-full max-w-md rounded-3xl p-6" style="background: rgb(252, 240, 228); border: 1px solid rgba(238, 136, 138, 0.2); box-shadow: 0 40px 80px rgba(127, 85, 81, 0.25);">
      <div class="flex items-start justify-between gap-4 mb-0.5">
        <h2 class="font-beachday text-2xl" style="color: rgb(238, 136, 138);">How to Use This Site</h2>
        <button onclick="document.getElementById('help-modal').classList.add('hidden'); document.getElementById('help-modal').classList.remove('flex');"
                class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center transition-colors cursor-pointer font-titan-one text-xs"
                style="background: rgba(238, 136, 138, 0.1); border: 1px solid rgba(238, 136, 138, 0.25); color: rgba(127, 85, 81, 0.6);">
          ✕
        </button>
      </div>
      <p class="font-lilita-one text-xs mb-6" style="color: rgba(127, 85, 81, 0.55);">Everything you need to know in under 15 seconds</p>
      <div class="space-y-4 mb-6">
        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center font-titan-one text-sm" style="background: rgba(238,136,138,0.15); border: 1px solid rgba(238,136,138,0.35); color: rgb(238,136,138);">1</div>
          <div>
            <p class="font-titan-one text-sm" style="color: rgb(127, 85, 81);">Explore the Page</p>
            <p class="font-lilita-one text-xs mt-0.5" style="color: rgba(127, 85, 81, 0.6);">Scroll through to learn about the schedule, prizes, rules, judges, and FAQ.</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center font-titan-one text-sm" style="background: rgba(158,194,191,0.2); border: 1px solid rgba(158,194,191,0.4); color: rgb(100, 155, 151);">2</div>
          <div>
            <p class="font-titan-one text-sm" style="color: rgb(127, 85, 81);">Register</p>
            <p class="font-lilita-one text-xs mt-0.5" style="color: rgba(127, 85, 81, 0.6);">Click "Register Now" and fill out your info. Join an existing team or create a new one (max 4 members).</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center font-titan-one text-sm" style="background: rgba(238,136,138,0.12); border: 1px solid rgba(238,136,138,0.28); color: rgb(200, 100, 102);">3</div>
          <div>
            <p class="font-titan-one text-sm" style="color: rgb(127, 85, 81);">Check the FAQ</p>
            <p class="font-lilita-one text-xs mt-0.5" style="color: rgba(127, 85, 81, 0.6);">Have questions? The FAQ section covers the most common ones — scroll down to find it.</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <div class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center font-titan-one text-sm" style="background: rgba(158,194,191,0.15); border: 1px solid rgba(158,194,191,0.35); color: rgb(100, 155, 151);">4</div>
          <div>
            <p class="font-titan-one text-sm" style="color: rgb(127, 85, 81);">Show Up & Compete</p>
            <p class="font-lilita-one text-xs mt-0.5" style="color: rgba(127, 85, 81, 0.6);">Come to the event and follow the schedule. Work with your team and submit your idea!</p>
          </div>
        </div>
      </div>
      <div class="pt-4" style="border-top: 1px solid rgba(127, 85, 81, 0.15);">
        <p class="font-titan-one text-xs uppercase tracking-widest mb-4" style="color: rgba(127, 85, 81, 0.5);">Still need help? Contact productTAMU</p>
        <div class="flex flex-wrap gap-2">
          <a href="https://discord.com/invite/ESucN2Mq6u" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-lilita-one transition-all"
             style="background: rgba(158,194,191,0.15); border: 1px solid rgba(158,194,191,0.35); color: rgb(100, 155, 151);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.031.053a19.9 19.9 0 005.993 3.03.077.077 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
            Discord
          </a>
          <a href="https://www.instagram.com/tamuproduct/" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-lilita-one transition-all"
             style="background: rgba(238,136,138,0.12); border: 1px solid rgba(238,136,138,0.3); color: rgb(200, 100, 102);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @tamuproduct
          </a>
          <a href="https://www.linkedin.com/company/productattamu/" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-lilita-one transition-all"
             style="background: rgba(158,194,191,0.15); border: 1px solid rgba(158,194,191,0.35); color: rgb(100, 155, 151);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <button onclick="navigator.clipboard.writeText('product.tamu@gmail.com').then(() => { this.textContent = '✓ Copied!'; setTimeout(() => { this.innerHTML = '<svg class=\'w-3.5 h-3.5\' fill=\'currentColor\' viewBox=\'0 0 24 24\'><path d=\'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z\'/></svg> product.tamu@gmail.com'; }, 2000) })"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-lilita-one transition-all cursor-pointer"
                  style="background: rgba(127, 85, 81, 0.08); border: 1px solid rgba(127, 85, 81, 0.2); color: rgba(127, 85, 81, 0.7);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            product.tamu@gmail.com
