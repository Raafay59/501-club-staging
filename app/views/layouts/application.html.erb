<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "501 Club - Ideathon Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if logged_in? && current_user.authorized? %>
      <nav class="app-nav" aria-label="Main">
        <div class="app-nav__links">
          <%= link_to "Ideathons", ideathons_path %>
          <span class="app-nav__sep" aria-hidden="true">|</span>
          <%= link_to "Sponsors & Partners", sponsors_partners_path %>
          <span class="app-nav__sep" aria-hidden="true">|</span>
          <%= link_to "Mentors & Judges", mentors_judges_path %>
          <span class="app-nav__sep" aria-hidden="true">|</span>
          <%= link_to "FAQs", faqs_path %>
          <span class="app-nav__sep" aria-hidden="true">|</span>
          <%= link_to "Rules", rules_path %>
          <span class="app-nav__sep" aria-hidden="true">|</span>
          <%= link_to "Activity Log", activity_logs_path %>
          <% if admin? %>
            <span class="app-nav__sep" aria-hidden="true">|</span>
            <%= link_to "Manage Users", users_path %>
          <% end %>
        </div>
        <div class="app-nav__user">
          <span>Signed in as <strong><%= current_user.name %></strong> (<%= current_user.role %>)</span>
          <%= button_to "Sign Out", logout_path, method: :delete %>
        </div>
      </nav>
    <% end %>

    <main class="app-main">
      <% if notice %>
        <p class="flash flash--notice" role="status"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="flash flash--alert" role="alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
