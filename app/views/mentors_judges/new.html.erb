<h1>New Mentor/Judge</h1>

<%= form_with(model: @mentors_judge, local: true) do |form| %>
  <% if @mentors_judge.errors.any? %>
    <div class="form-errors" role="alert">
      <h3><%= pluralize(@mentors_judge.errors.count, "error") %> prohibited this record from being saved:</h3>
      <ul>
        <% @mentors_judge.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% include_photo = if params.dig(:mentors_judge, :include_photo).present?
    params.dig(:mentors_judge, :include_photo) == "1"
  else
    @mentors_judge.photo_url.present? || @mentors_judge.new_record?
  end %>

  <div>
    <%= form.label :year %>
    <%= form.select :year, @ideathon_years, prompt: "Select Ideathon Year" %>
  </div>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :job_title %>
    <%= form.text_field :job_title %>
  </div>

  <div>
    <%= label_tag :mentors_judge_include_photo, "Include profile photo?" %>
    <%= hidden_field_tag "mentors_judge[include_photo]", "0" %>
    <%= check_box_tag "mentors_judge[include_photo]", "1", include_photo, id: "mentors_judge_include_photo" %>
    <p>Uncheck to publish this mentor/judge without a photo.</p>
  </div>

  <div>
    <%= form.label :photo_url, "Photo URL (optional)" %>
    <%= form.text_field :photo_url %>
  </div>

  <div>
    <%= form.label :bio %>
    <%= form.text_area :bio %>
  </div>

  <div>
    <%= form.label :is_judge, "Is Judge?" %>
    <%= form.check_box :is_judge %>
  </div>

  <div>
    <%= form.submit "Create Mentor/Judge" %>
  </div>
<% end %>

<br>
<%= link_to "Back to Mentors & Judges", mentors_judges_path %>
