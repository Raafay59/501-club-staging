<h1>Mentors & Judges</h1>

<table class="data-table">
  <thead>
    <tr>
      <th>Year</th>
      <th>Name</th>
      <th>Job Title</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @mentors_judges.each do |mj| %>
      <tr>
        <td><%= mj.year %></td>
        <td><%= mj.name %></td>
        <td><%= mj.job_title.presence || "-" %></td>
        <td><%= mj.is_judge? ? "Judge" : "Mentor" %></td>
        <td>
          <%= link_to "View", mentors_judge_path(mj) %> |
          <%= link_to "Edit", edit_mentors_judge_path(mj) %>
          <% if admin? %>
            | <%= link_to "Delete", delete_mentors_judge_path(mj) %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
<%= link_to "New Mentor/Judge", new_mentors_judge_path %>

<% if admin? %>
  <hr>
  <h2>Import Mentors/Judges from CSV</h2>
  <p>CSV columns: <code>year, name, job_title, photo_url, bio, is_judge</code> (photo_url is optional)</p>
  <%= form_with url: import_mentors_judges_path, local: true, multipart: true do |form| %>
    <%= context_field_tip("import.mentors_judges") do %>
      <div>
        <%= form.label :file, "Select CSV file" %>
        <%= form.file_field :file, accept: ".csv,text/csv" %>
      </div>
    <% end %>
    <div>
      <%= form.submit "Import" %>
    </div>
  <% end %>

  <h2>Export Judges to CSV</h2>
  <%= link_to "Export", export_mentors_judges_path(format: :csv) %>
<% end %>
