<h1>FAQs</h1>

<table class="data-table">
  <thead>
    <tr>
      <th>Year</th>
      <th>Question</th>
      <th>Answer</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @faqs.each do |faq| %>
      <tr>
        <td><%= faq.year %></td>
        <td><%= truncate(faq.question, length: 80) %></td>
        <td><%= truncate(faq.answer, length: 80) %></td>
        <td>
          <%= link_to "View", faq_path(faq) %> |
          <%= link_to "Edit", edit_faq_path(faq) %>
          <% if admin? %>
            | <%= link_to "Delete", delete_faq_path(faq) %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
<%= link_to "New FAQ", new_faq_path %>

<% if admin? %>
  <hr>
  <h2>Import FAQs from CSV</h2>
  <p>CSV columns: <code>year, question, answer</code></p>
  <%= form_with url: import_faqs_path, local: true, multipart: true do |form| %>
    <%= context_field_tip("import.faqs") do %>
      <div>
        <%= form.label :file, "Select CSV file" %>
        <%= form.file_field :file, accept: ".csv,text/csv" %>
      </div>
    <% end %>
    <div>
      <%= form.submit "Import" %>
    </div>
  <% end %>
<% end %>
