      <% [
        { title: "Innovation", description: "Originality and creativity of the idea." },
        { title: "Feasibility", description: "Can the solution realistically be implemented?" },
        { title: "Impact", description: "Potential to solve a meaningful problem." },
        { title: "User-Centric Thinking", description: "Understanding of the target audience." },
        { title: "Business Viability", description: "Scalability and sustainability." },
        { title: "Presentation Quality", description: "Clarity, storytelling, and persuasion." }
      ].each_with_index do |criterion, index| %>
        <div class="bento-card ideathon-panel rounded-2xl p-6 transition-all duration-300">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-6 w-6 rounded-lg border" style="background-color: rgba(228, 240, 171, 0.15); border-color: rgba(228, 240, 171, 0.25);">
                <span class="font-titan-one text-xs" style="color: rgb(228, 240, 171);"><%= index + 1 %></span>
              </div>
            </div>
            <div>
              <h3 class="font-titan-one text-white text-sm mb-1"><%= criterion[:title] %></h3>
              <p class="font-lilita-one text-white text-sm"><%= criterion[:description] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</section>


