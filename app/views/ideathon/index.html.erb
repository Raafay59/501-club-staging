<%# Schedule section %>
<section id="schedule" class="relative z-10 py-20 px-4">
  <div class="max-w-5xl mx-auto">
    
    <div class="text-center mb-16">
      <h2 class="section-heading">
        EVENT <span style="color: rgb(215, 129, 112);">SCHEDULE</span>
      </h2>
      <p class="section-subheading">
        24 hours of innovation, collaboration, and fun
      </p>
    </div>
    
    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical Line - stops before the end -->
      <div class="absolute left-4 md:left-1/2 top-0 w-1 rounded-full" style="height: calc(100% - 60px); background: linear-gradient(to bottom, rgb(252, 240, 228), rgb(238, 136, 138), rgb(158, 194, 191));"></div>
      
      <% if @events.any? %>
        <% @events.group_by { |e| e.event_date }.each_with_index do |(date, day_events), day_index| %>
          <!-- Day Header -->
          <div class="relative flex justify-center mb-8 mt-12">
            <div class="font-titan-one px-6 py-2 rounded-full shadow-lg z-10" style="<%= day_index.even? ? 'background-color: rgb(252, 240, 228); color: rgb(215, 129, 112);' : 'background-color: rgb(215, 129, 112); color: white;' %>">
              Day <%= day_index + 1 %> - <%= date.strftime("%B %d") %>
            </div>
          </div>
          
          <div class="space-y-6">
            <% day_events.each_with_index do |event, index| %>
              <!-- Event -->
              <div class="relative flex items-center gap-6 md:gap-0">
                <% if index.even? %>
                  <!-- Left side (desktop) -->
                  <div class="hidden md:block md:w-1/2 md:pr-8 md:text-right">
                    <div class="bento-card ideathon-panel ideathon-panel--schedule inline-block rounded-2xl p-5">
                      <div class="font-titan-one text-lg" style="color: rgb(238, 136, 138);"><%= event.event_time.strftime("%l:%M %p") %></div>
                      <div class="font-lilita-one text-white text-base"><%= event.event_name %></div>
                      <div class="font-lilita-one text-white text-sm"><%= event.event_description %></div>
                    </div>
                  </div>
                <% else %>
                  <!-- Left empty (desktop) -->
                  <div class="hidden md:block md:w-1/2 md:pr-8"></div>
                <% end %>
                
                <!-- Center icon -->
                <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 w-10 h-10 z-10">
                  <img src="/images/pinkflower.png" alt="" class="w-full h-full object-contain" />
                </div>
                
                <!-- Mobile version -->
                <div class="md:hidden ml-12 bento-card ideathon-panel ideathon-panel--schedule rounded-2xl p-5 flex-1">
                  <div class="font-titan-one text-lg" style="color: rgb(238, 136, 138);"><%= event.event_time.strftime("%l:%M %p") %></div>
                  <div class="font-lilita-one text-white text-base"><%= event.event_name %></div>
                  <div class="font-lilita-one text-white text-sm"><%= event.event_description %></div>
                </div>
                
                <% if index.even? %>
                  <!-- Right empty (desktop) -->
                  <div class="hidden md:block md:w-1/2 md:pl-8"></div>
                <% else %>
                  <!-- Right side (desktop) -->
                  <div class="ml-12 md:ml-0 md:w-1/2 md:pl-8">
                    <div class="bento-card ideathon-panel ideathon-panel--schedule inline-block rounded-2xl p-5">
                      <div class="font-titan-one text-lg" style="color: rgb(215, 129, 112);"><%= event.event_time.strftime("%l:%M %p") %></div>
                      <div class="font-lilita-one text-white text-base"><%= event.event_name %></div>
                      <div class="font-lilita-one text-white text-sm"><%= event.event_description %></div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-12">
          <p class="font-lilita-one text-white text-lg">No events scheduled yet</p>
        </div>
      <% end %>
    </div>
  </div>
</section>


