
<%# TAMU Ideathon 2026 landing page %>
<% content_for :title, "TAMU Ideathon 2026 - Where Ideas Come to Life" %>

<!-- Extra Falling Leaves -->
<div class="absolute inset-0 w-full h-full pointer-events-none -z-10">
  <img src="/images/sakura-bg.jpg" style="width:100vw;height:100vh;object-fit:cover;position:absolute;top:0;left:0;z-index:-1;" alt="Sakura Cherry Blossom Background" />
  <svg class="falling-leaf" style="position:absolute;left:10vw;top:-60px;width:40px;height:40px;" viewBox="0 0 40 40">
    <ellipse cx="20" cy="20" rx="16" ry="8" fill="#F9B5D0"/>
  </svg>
  <svg class="falling-leaf" style="position:absolute;left:30vw;top:-80px;width:32px;height:32px;" viewBox="0 0 32 32">
    <ellipse cx="16" cy="16" rx="12" ry="6" fill="#A3C9A8"/>
  </svg>
  <svg class="falling-leaf" style="position:absolute;left:60vw;top:-70px;width:36px;height:36px;" viewBox="0 0 36 36">
    <ellipse cx="18" cy="18" rx="14" ry="7" fill="#F9B5D0"/>
  </svg>
  <svg class="falling-leaf" style="position:absolute;left:80vw;top:-90px;width:28px;height:28px;" viewBox="0 0 28 28">
    <ellipse cx="14" cy="14" rx="10" ry="5" fill="#A3C9A8"/>
  </svg>
</div>
<style>
@keyframes leafFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  80% { opacity: 1; }
  100% { transform: translateY(100vh) rotate(360deg); opacity: 0.5; }
}
.falling-leaf {
  animation: leafFall 7s linear infinite;
}
.falling-leaf:nth-child(2) { animation-delay: 1s; }
.falling-leaf:nth-child(3) { animation-delay: 2.5s; }
.falling-leaf:nth-child(4) { animation-delay: 4s; }
.falling-leaf:nth-child(5) { animation-delay: 5.5s; }
</style>

<%# Consolidated Styles - Glassmorphism, animations, and reusable classes %>
<% content_for :head do %>
<style>
  * { -webkit-font-smoothing: antialiased; }

  /* Glass Effects — higher opacity so text stays readable on busy backgrounds */
  .glass {
    background: rgba(255, 255, 255, 0.38);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.38);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.28);
    transform: translateZ(0);
  }

  .glass-solid {
    background: rgba(255, 255, 255, 0.42);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.32);
    transform: translateZ(0);
  }

  /* Card shell — layout only (fills use .ideathon-panel below) */
  .bento-card {
    transform: translateZ(0);
  }

  /*
   * Solid frosted panels: explicit rgba backgrounds so we never depend on Tailwind opacity
   * utilities (which may not compile for this template). Keeps white body text readable.
   */
  .ideathon-panel {
    background-color: rgba(52, 38, 34, 0.94);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    border: 1px solid rgba(255, 255, 255, 0.42);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.32);
  }

  .ideathon-panel--schedule {
    background: linear-gradient(150deg, rgba(78, 56, 50, 0.96), rgba(42, 30, 27, 0.94));
    border-color: rgba(255, 255, 255, 0.45);
  }

  .ideathon-panel--hover:hover {
    border-color: rgba(255, 255, 255, 0.62);
  }

  /* Slight shadow on light text over frosted panels improves contrast */
  .bento-card .font-lilita-one.text-white,
  .bento-card .font-titan-one.text-white {
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.58);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  .glass-card-subtle {
    background: rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.45);
  }

  /* Shadows */
  .shadow-dark {
    box-shadow: 0 4px 6px rgba(0,0,0,0.4), 8px 8px 0px 0px rgba(0,0,0,0.7);
  }

  .shadow-glow {
    box-shadow: 0 0 30px rgba(238, 136, 138, 0.3);
  }

  /* Glows */
  .glow-gold {
    box-shadow: 0 0 15px rgba(238, 136, 138, 0.2);
  }

  .glow-green {
    box-shadow: 0 0 15px rgba(228,240,171,0.15);
  }

  /* Section Headers */
  .section-heading {
    font-family: 'Beach Day', sans-serif;
    font-size: clamp(2rem, 5vw, 3.75rem);
    color: white;
    margin-bottom: 1rem;
    drop-shadow: 0 0 40px rgba(255,255,255,0.8);
  }

  .section-subheading {
    font-family: 'Lilita One', sans-serif;
    font-size: 1.125rem;
    color: white;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Nav Links */
  .nav-link {
    font-family: 'Lilita One', sans-serif;
    color: white;
    transition: color 200ms, background-color 200ms;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
  }

  .nav-link:hover {
    color: rgb(238, 136, 138);
    background-color: rgba(255, 255, 255, 0.05);
  }

  /* Badge */
  .event-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 9999px;
    padding: 0.375rem 1.25rem;
    margin-bottom: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .event-badge-text {
    font-family: 'Lilita One', sans-serif;
    color: white;
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
  }

  /* Animations */
  .animate-init { opacity: 0; }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .mobile-menu-enter { animation: mobileMenuEnter 0.3s cubic-bezier(0.16,1,0.3,1) forwards; }
  .mobile-menu-exit  { animation: mobileMenuExit 0.25s ease-out forwards; }
  
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @keyframes mobileMenuEnter {
    0%   { opacity: 0; transform: translateY(-16px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @keyframes mobileMenuExit {
    0%   { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-16px); }
  }

  .leaf {
    position: fixed;
    top: -50px;
    width: 30px;
    height: 30px;
    background-image: url('/images/leaf.png');
    background-size: contain;
    background-repeat: no-repeat;
    animation-name: fall;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .leaf:nth-child(odd) {
    animation-duration: 6s;
    left: 20%;
  }

  .leaf:nth-child(even) {
    animation-duration: 10s;
    left: 60%;
  }

  @keyframes fall {
    0% {
      transform: translateY(0) rotate(0deg);
    }
    100% {
      transform: translateY(100vh) rotate(360deg);
    }
  }
</style>

<% end %>


