      <div class="text-center mb-6">
        <span class="font-titan-one text-sm tracking-widest uppercase" style="color: rgb(215, 129, 112);">Gold Sponsors</span>
      </div>
      <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10">
