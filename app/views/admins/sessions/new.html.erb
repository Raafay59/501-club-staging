<% content_for :title, "Sign In - TAMU Ideathon 2026" %>

<% content_for :head do %>
<meta name="turbo-cache-control" content="no-cache">

<style>
  body {
    background-color: rgb(255, 220, 230) !important;
  }
  .login-card {
    background: rgb(252, 240, 228);
    border: 1px solid rgba(238, 136, 138, 0.2);
    box-shadow: 0 20px 60px rgba(127, 85, 81, 0.12);
  }
  .btn-google {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(127, 85, 81, 0.15);
    transition: all 0.3s ease;
  }
  .btn-google:hover {
    background: rgba(238, 136, 138, 0.12);
    border-color: rgba(238, 136, 138, 0.4);
    box-shadow: 0 0 20px rgba(238, 136, 138, 0.15);
  }
  .back-link {
    color: rgba(127, 85, 81, 0.5);
  }
  .back-link:hover {
    color: rgb(238, 136, 138);
  }
</style>
<% end %>

<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <!-- Back to home -->
    <div class="mb-8 text-center">
      <%= link_to root_path, class: "back-link inline-flex items-center gap-2 transition-colors text-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Home
      <% end %>
    </div>

    <!-- Login card -->
    <div class="login-card rounded-2xl p-8 sm:p-10 text-center">
      <!-- Title -->
      <%= link_to root_path do %>
        <h1 class="font-beachday text-3xl sm:text-4xl tracking-wide mb-2 hover:opacity-80 transition-opacity" style="color: rgb(238, 136, 138);">
          TAMU IDEATHON
        </h1>
      <% end %>
      <p class="text-sm mb-8" style="color: rgba(127, 85, 81, 0.55);">
        Sign in to access the Manager Dashboard
      </p>

      <!-- Alert -->
      <% if alert.present? %>
        <div class="mb-6 rounded-lg px-4 py-3 text-sm text-red-600" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2);">
          <%= alert %>
        </div>
      <% end %>

      <!-- Google sign in button -->
      <%= button_to admin_google_oauth2_omniauth_authorize_path(prompt: "select_account"), method: :post, data: { turbo: "false" }, class: "btn-google w-full rounded-xl px-6 py-4 flex items-center justify-center gap-3 font-semibold text-base cursor-pointer", style: "color: rgb(127, 85, 81);" do %>
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Sign in with Google
      <% end %>

      <p class="text-xs mt-6" style="color: rgba(127, 85, 81, 0.35);">
        Manager access only
      </p>
    </div>
  </div>
</div>
