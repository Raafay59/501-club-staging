<h1>New Ideathon</h1>

<%= form_with(model: @ideathon, url: ideathons_path, local: true) do |form| %>
  <% if @ideathon.errors.any? %>
    <div class="form-errors" role="alert">
      <h3><%= pluralize(@ideathon.errors.count, "error") %> prohibited this ideathon from being saved:</h3>
      <ul>
        <% @ideathon.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :year %>
    <%= form.number_field :year, min: 2000, max: 2100, step: 1 %>
  </div>

  <div>
    <%= form.label :theme %>
    <%= form.text_field :theme %>
  </div>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4 %>
  </div>

  <div>
    <%= form.label :location %>
    <%= form.text_field :location %>
  </div>

  <div>
    <%= form.label :start_date %>
    <%= form.date_field :start_date %>
  </div>

  <div>
    <%= form.label :end_date %>
    <%= form.date_field :end_date %>
  </div>

  <div>
    <%= form.label :is_active, "Show this year on public site" %>
    <%= form.check_box :is_active %>
  </div>

  <div>
    <%= form.submit "Create Ideathon" %>
  </div>
<% end %>

<br>
<%= link_to "Back to Ideathons", ideathons_path %>
