<h1>Ideathons</h1>

<p><%= link_to "Activity Log", activity_logs_path %> - view changes to ideathons, sponsors, judges, FAQs, and photos.</p>

<table class="data-table">
  <thead>
    <tr>
      <th>Year</th>
      <th>Theme</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @ideathons.each do |ideathon| %>
      <tr>
        <td><%= ideathon.year %></td>
        <td><%= ideathon.theme %></td>
        <td>
          <% if ideathon.year.present? %>
            <%= link_to "Overview", overview_ideathon_path(year: ideathon.year) %> |
            <%= link_to "View", ideathon_path(year: ideathon.year) %> |
            <%= link_to "Edit", edit_ideathon_path(year: ideathon.year) %>
            <% if admin? %>
              | <%= link_to "Delete", delete_ideathon_path(year: ideathon.year) %>
            <% end %>
          <% else %>
            <span>Missing year</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
<%= link_to "New Ideathon", new_ideathon_path %>

<% if admin? %>
  <hr>
  <h2>Import Ideathons from CSV</h2>
  <p>CSV columns: <code>year, theme</code></p>
  <%= form_with url: import_ideathons_path, local: true, multipart: true do |form| %>
    <%= context_field_tip("import.ideathons") do %>
      <div>
        <%= form.label :file, "Select CSV file" %>
        <%= form.file_field :file, accept: ".csv,text/csv" %>
      </div>
    <% end %>
    <div>
      <%= form.submit "Import" %>
    </div>
  <% end %>
<% end %>
