<% content_for :title, "Manager Dashboard - TAMU Ideathon 2026" %>

<% content_for :head do %>
<meta name="turbo-cache-control" content="no-cache">
<style>
  .manager-page,
  .manager-page * {
    color: rgb(127, 85, 81) !important;
  }
  .manager-page .manager-title {
    color: rgb(238, 136, 138) !important;
  }
  .manager-page .accent-text {
    color: rgb(158, 194, 191) !important;
  }
  .manager-page .accent-hover:hover {
    color: rgb(158, 194, 191) !important;
  }
  body {
    background-color: rgb(255, 249, 246) !important;
    color: rgb(127, 85, 81);
  }
  .glass-card {
    background: rgb(252, 240, 228);
    border: 1px solid rgba(238, 136, 138, 0.15);
  }
  .glass-card:hover {
    background: rgb(250, 235, 222);
    border-color: rgba(158, 194, 191, 0.4);
  }
  .glass-search {
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(158, 194, 191, 0.45);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .glass-search:focus-within {
    border-color: rgba(158, 194, 191, 0.7);
    box-shadow: 0 0 0 3px rgba(158, 194, 191, 0.15);
  }
  .glass-search input {
    outline: none;
    box-shadow: none;
  }
  .glass-search input:focus {
    outline: none;
    box-shadow: none;
  }
  .btn-edit {
    background: rgba(158, 194, 191, 0.08);
    border: 1px solid rgba(158, 194, 191, 0.2);
    transition: all 0.2s ease;
  }
  .btn-edit:hover {
    background: rgba(158, 194, 191, 0.18);
    border-color: rgba(158, 194, 191, 0.45);
  }
  .btn-delete {
    background: rgba(255, 49, 49, 0.15);
    border: 1px solid rgba(255, 49, 49, 0.3);
    transition: all 0.2s ease;
  }
  .btn-delete:hover {
    background: rgba(255, 49, 49, 0.3);
    border-color: rgba(255, 49, 49, 0.6);
    box-shadow: 0 0 15px rgba(255, 49, 49, 0.2);
  }
  .badge {
    background: rgba(158, 194, 191, 0.15);
    border: 1px solid rgba(158, 194, 191, 0.3);
  }
  .sort-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: all 0.2s ease;
  }
  .sort-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  .sort-btn-active {
    background: rgba(158, 194, 191, 0.15);
    border-color: rgba(158, 194, 191, 0.4);
    color: rgb(158, 194, 191);
  }
  .outlined-control {
    border: 1px solid rgba(158, 194, 191, 0.55) !important;
  }
  .attr-box {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  details summary::-webkit-details-marker { display: none; }
  .tab-bar { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }
  .tab-btn { background: transparent; border: 1px solid transparent; transition: all 0.2s ease; color: rgba(255,255,255,0.4); }
  .tab-btn:hover { color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.05); }
  .tab-active { background: rgba(158,194,191,0.12) !important; border-color: rgba(158,194,191,0.35) !important; color: rgb(158, 194, 191) !important; }
  .search-icon-crisp {
    color: rgb(127, 85, 81) !important;
  }
  [data-tooltip] { position: relative; }
  [data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(5, 8, 28, 0.96);
    border: 1px solid rgba(158, 194, 191, 0.2);
    color: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
    transition-delay: 0s;
    z-index: 100;
  }
  [data-tooltip]:hover::before {
    opacity: 1;
    transition-delay: 0.6s;
  }
</style>
<% end %>

<div class="manager-page min-h-screen px-4 py-8 sm:px-6 lg:px-8">
  <!-- Top bar -->
  <div class="max-w-5xl mx-auto mb-6 flex items-center justify-between">
    <%= link_to root_path, class: "inline-flex items-center gap-2 accent-hover transition-colors text-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Home
    <% end %>
    <div class="flex items-center gap-4">
      <%= link_to "Export Participants CSV",
                  export_participants_manager_index_path(request.query_parameters.merge(format: :csv)),
                  class: "text-xs px-3 py-1.5 rounded-md bg-white/10 hover:bg-white/20 text-white transition-colors",
                  data: { turbo: false, turbo_prefetch: false } %>
      <%= link_to "Export Teams CSV",
                  export_teams_manager_index_path(request.query_parameters.merge(format: :csv)),
                  class: "text-xs px-3 py-1.5 rounded-md bg-white/10 hover:bg-white/20 text-white transition-colors",
                  data: { turbo: false, turbo_prefetch: false } %>
      <%= link_to "Heroku Documentation", view_pdf_manager_index_path, target: "_blank",
                  class: "text-xs px-3 py-1.5 rounded-md bg-white/10 hover:bg-white/20 text-white transition-colors" %>
      <button onclick="document.getElementById('dev-contacts-modal').classList.remove('hidden'); document.getElementById('dev-contacts-modal').classList.add('flex');"
              class="text-xs px-3 py-1.5 rounded-full transition-colors cursor-pointer font-semibold"
              style="background: rgba(158, 194, 191, 0.1); border: 1px solid rgba(158, 194, 191, 0.3); color: rgb(100, 155, 151);">
        Dev Contacts
      </button>
      <button onclick="document.getElementById('manager-help-modal').classList.remove('hidden'); document.getElementById('manager-help-modal').classList.add('flex');"
              class="text-xs px-4 py-1.5 rounded-full transition-colors cursor-pointer font-semibold"
              style="background: rgba(238, 136, 138, 0.1); border: 1px solid rgba(238, 136, 138, 0.25); color: rgb(238, 136, 138);">
        ? Help
      </button>
      <%= button_to "Sign Out", logout_path, method: :delete, class: "text-white/30 hover:text-white/60 text-xs transition-colors bg-transparent border-0 p-0 cursor-pointer" %>
    </div>
  </div>

  <div class="max-w-5xl mx-auto" data-controller="manager-tabs">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="manager-title text-3xl sm:text-4xl font-beachday tracking-wide" style="color: rgb(238, 136, 138);">
        Manager Dashboard
      </h1>
      <p class="text-white/50 text-sm mt-1">
        Manage attendees and events
      </p>
      <div class="mt-6 flex gap-3">
        <span class="badge rounded-full px-4 py-1.5 accent-text text-sm font-semibold">
          <%= @registered_attendees.size %> attendee<%= @registered_attendees.size == 1 ? '' : 's' %>
        </span>
        <span class="badge rounded-full px-4 py-1.5 accent-text text-sm font-semibold">
          <%= @teams_count %> team<%= @teams_count == 1 ? '' : 's' %>
        </span>
        <span class="badge rounded-full px-4 py-1.5 accent-text text-sm font-semibold">
          <%= @events.size %> event<%= @events.size == 1 ? '' : 's' %>
        </span>
      </div>
    </div>

    <!-- Tab Bar -->
    <div class="tab-bar flex gap-1 p-1 rounded-xl mb-8 w-fit">
      <button class="tab-btn rounded-lg px-5 py-2.5 text-sm font-semibold inline-flex items-center gap-2"
              data-manager-tabs-target="tab" data-tab="attendees"
              data-action="click->manager-tabs#switch"
              data-tooltip="View and manage attendees">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        Attendees
      </button>
      <button class="tab-btn rounded-lg px-5 py-2.5 text-sm font-semibold inline-flex items-center gap-2"
              data-manager-tabs-target="tab" data-tab="events"
              data-action="click->manager-tabs#switch"
              data-tooltip="View and manage events">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Events
      </button>
      <button class="tab-btn rounded-lg px-5 py-2.5 text-sm font-semibold inline-flex items-center gap-2"
              data-manager-tabs-target="tab" data-tab="activity"
              data-action="click->manager-tabs#switch"
              data-tooltip="View recent manager actions">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z" />
        </svg>
        Activity
      </button>
    </div>

    <!-- Attendees Panel -->
    <div data-manager-tabs-target="panel" data-tab="attendees"
         class="transition-all duration-200 ease-out opacity-100 translate-y-0">

      <!-- Search + Sort + Add -->
      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <!-- Search -->
        <%= form_with url: manager_index_path, method: :get, data: { controller: "manager-search", turbo_frame: "attendees_list" }, class: "flex-1" do |f| %>
          <%= f.hidden_field :sort, value: @sort %>
          <div class="glass-search outlined-control rounded-xl flex items-center gap-2 px-4 py-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="search-icon-crisp h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <%= f.text_field :query,
                value: params[:query],
                placeholder: "Search by name or team...",
                autocomplete: "off",
                class: "flex-1 bg-transparent outline-none text-sm",
                data: { manager_search_target: "input", action: "input->manager-search#search" } %>
          </div>
        <% end %>

        <!-- Sort Toggle -->
        <div class="flex gap-2 flex-shrink-0">
          <%= link_to manager_index_path(sort: "team", query: params[:query]),
              class: "sort-btn #{@sort == 'team' ? 'sort-btn-active' : 'text-white/50'} rounded-xl px-4 py-3 text-sm font-semibold inline-flex items-center gap-2",
              data: { turbo_frame: "attendees_list", tooltip: "Group attendees by team" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            By Team
          <% end %>
          <%= link_to manager_index_path(sort: "name", query: params[:query]),
              class: "sort-btn outlined-control sort-btn-active rounded-xl px-4 py-3 text-sm font-semibold inline-flex items-center gap-2",
              data: { turbo_frame: "attendees_list", tooltip: "Sort attendees alphabetically" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            By Name
          <% end %>
          <%= link_to new_registered_attendee_path(return_to: "manager"),
              class: "sort-btn outlined-control sort-btn-active rounded-xl px-4 py-3 text-sm font-semibold inline-flex items-center gap-2",
              data: { tooltip: "Register a new attendee" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Add Attendee
          <% end %>
        </div>
      </div>

      <!-- Attendee List -->
      <%= turbo_frame_tag "attendees_list" do %>
        <% if @registered_attendees.any? %>
          <% if @sort == "team" %>
            <% grouped = @registered_attendees.group_by { |a| a.team&.unassigned ? "Unassigned" : (a.team&.team_name || "No Team") } %>
            <div class="space-y-4">
              <% grouped.each do |team_name, attendees| %>
                <details class="group">
                  <summary class="list-none flex items-center justify-between px-4 py-2 rounded-lg cursor-pointer select-none"
                          style="background: rgba(158, 194, 191, 0.08); border: 1px solid rgba(158, 194, 191, 0.2);">
                        <h2 class="accent-text text-sm font-semibold inline-flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                      <%= team_name %>
                      <span class="text-white/30 font-normal">(<%= attendees.size %>)</span>
                    </h2>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 accent-text transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="space-y-3 mt-3">
                    <% attendees.each do |attendee| %>
                      <%= render partial: "manager/attendee_card", locals: { attendee: attendee } %>
                    <% end %>
                  </div>
                </details>
              <% end %>
            </div>
          <% else %>
            <div class="space-y-3">
              <% @registered_attendees.each do |attendee| %>
                <%= render partial: "manager/attendee_card", locals: { attendee: attendee } %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="glass-card rounded-xl p-12 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-white/20 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <p class="text-white/40 text-sm">
              <% if params[:query].present? %>
                No attendees match "<%= params[:query] %>"
              <% else %>
                No registered attendees yet.
              <% end %>
            </p>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Events Panel -->
    <div data-manager-tabs-target="panel" data-tab="events"
         class="transition-all duration-200 ease-out hidden opacity-0 translate-y-2">

      <!-- Add Event button -->
      <div class="flex justify-end mb-8">
        <%= link_to new_ideathon_event_path,
            class: "sort-btn text-white/50 rounded-xl px-4 py-3 text-sm font-semibold inline-flex items-center gap-2",
            data: { tooltip: "Create a new event" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Add Event
        <% end %>
      </div>

      <!-- Events List -->
      <% if @events.any? %>
        <div class="space-y-3">
          <% @events.each do |event| %>
            <%= render partial: "manager/event_card", locals: { event: event } %>
          <% end %>
        </div>
      <% else %>
        <div class="glass-card rounded-xl p-12 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-white/20 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-white/40 text-sm">No events scheduled yet.</p>
        </div>
      <% end %>
    </div>

    <!-- Activity Panel -->
    <div data-manager-tabs-target="panel" data-tab="activity"
         class="transition-all duration-200 ease-out hidden opacity-0 translate-y-2">
      <div class="glass-card rounded-2xl p-5 sm:p-6">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="accent-text text-lg font-semibold">Action Log</h2>
            <p class="text-white/40 text-xs mt-0.5">Most recent manager actions across all admins</p>
          </div>
          <span class="badge rounded-full px-3 py-1 accent-text text-xs font-semibold">
            <%= @action_logs.size %> shown
          </span>
        </div>

        <%= render partial: "manager/action_logs", locals: { action_logs: @action_logs } %>
      </div>
    </div>
  </div>

</div>

<!-- Developer Contacts Modal -->
<div id="dev-contacts-modal" class="fixed inset-0 hidden items-center justify-center p-4" style="z-index: 99999; background: rgba(127, 85, 81, 0.35); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
     onclick="if(event.target===this){this.classList.add('hidden');this.classList.remove('flex');}">
  <div class="w-full max-w-2xl rounded-3xl p-6" style="background: rgb(252, 240, 228); border: 1px solid rgba(238, 136, 138, 0.2); box-shadow: 0 40px 80px rgba(127, 85, 81, 0.25);">
    <div class="flex items-start justify-between gap-4 mb-1">
      <h2 class="font-beachday text-2xl" style="color: rgb(238, 136, 138);">Developer Contacts</h2>
      <button onclick="document.getElementById('dev-contacts-modal').classList.add('hidden'); document.getElementById('dev-contacts-modal').classList.remove('flex');"
              class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center transition-colors cursor-pointer text-xs font-bold"
              style="background: rgba(238, 136, 138, 0.1); border: 1px solid rgba(238, 136, 138, 0.25); color: rgba(127, 85, 81, 0.6);">
        ✕
      </button>
    </div>
    <p class="text-xs mb-5" style="color: rgba(127, 85, 81, 0.55);">Reach out to the dev team for technical support</p>
    <div class="rounded-2xl overflow-hidden" style="border: 1px solid rgba(127, 85, 81, 0.1);">
      <table class="w-full text-sm">
        <thead>
          <tr style="background: rgba(158, 194, 191, 0.12); border-bottom: 1px solid rgba(158, 194, 191, 0.2);">
            <th class="text-left px-5 py-3 font-semibold text-xs uppercase tracking-wider" style="color: rgb(100, 155, 151);">Name</th>
            <th class="text-left px-5 py-3 font-semibold text-xs uppercase tracking-wider" style="color: rgb(100, 155, 151);">Phone</th>
            <th class="text-left px-5 py-3 font-semibold text-xs uppercase tracking-wider" style="color: rgb(100, 155, 151);">Email</th>
            <th class="text-left px-5 py-3 font-semibold text-xs uppercase tracking-wider" style="color: rgb(100, 155, 151);">Support Area</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid rgba(127, 85, 81, 0.08); background: rgba(255,255,255,0.4);">
            <td class="px-5 py-3 font-semibold" style="color: rgb(127, 85, 81);">Sam Nguyen</td>
            <td class="px-5 py-3" style="color: rgba(127, 85, 81, 0.7);">832-800-8396</td>
            <td class="px-5 py-3" style="color: rgba(127, 85, 81, 0.7);">tnnguyen0914@gmail.com</td>
            <td class="px-5 py-3">
              <span class="px-2 py-0.5 rounded-full text-xs" style="background: rgba(238, 136, 138, 0.12); border: 1px solid rgba(238, 136, 138, 0.3); color: rgb(200, 100, 102);">Manager Page Support</span>
            </td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(127, 85, 81, 0.08);">
            <td class="px-5 py-3 font-semibold" style="color: rgb(127, 85, 81);">Oscar Bravo</td>
            <td class="px-5 py-3" style="color: rgba(127, 85, 81, 0.7);">281-381-2947</td>
            <td class="px-5 py-3" style="color: rgba(127, 85, 81, 0.7);">oscarbravo@tamu.edu</td>
            <td class="px-5 py-3">
              <span class="px-2 py-0.5 rounded-full text-xs" style="background: rgba(158, 194, 191, 0.15); border: 1px solid rgba(158, 194, 191, 0.35); color: rgb(100, 155, 151);">Deployment & Action Logs</span>
            </td>
          </tr>
