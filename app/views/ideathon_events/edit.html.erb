<% content_for :title, "Edit Event - TAMU Ideathon 2026" %>
<% content_for :submit_label, "Update Event" %>
<% content_for :head do %>
<meta name="turbo-cache-control" content="no-cache">
<style>
  .back-link:hover { color: rgb(238, 136, 138); }
</style>
<% end %>

<div class="min-h-screen px-4 py-8 sm:px-6 lg:px-8">
  <div class="max-w-lg mx-auto">
    <!-- Back link -->
    <div class="mb-6">
      <%= link_to manager_index_path(tab: "events"), class: "back-link inline-flex items-center gap-2 text-white/50 transition-colors text-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Manager
      <% end %>
    </div>

    <!-- Form card -->
    <div class="event-card rounded-2xl p-6 sm:p-8">
      <h1 class="font-urban-blocker text-3xl sm:text-4xl tracking-wide text-center mb-1" style="color: rgb(238, 136, 138);">
        EDIT EVENT
      </h1>
      <p class="text-white/40 text-sm text-center mb-8">
        Ideathon 2026
      </p>

      <%= render "form", ideathon_event: @ideathon_event %>
    </div>
  </div>
</div>
