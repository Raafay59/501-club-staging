# Copy to `.env` for local development (loaded by dotenv-rails in development/test).

# --- Google OAuth (Devise / OmniAuth) ---
# Canonical names:
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Also accepted (e.g. Heroku apps that used these names historically):
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Admin allowlist ---
# Comma, semicolon, or newline-separated emails allowed to complete staff sign-in.
# Leave empty only when you intentionally rely on legacy cutover behavior (see README).
ALLOWED_ADMIN_EMAILS=""

# --- Local database overrides (optional) ---
# On some Windows setups, forcing IPv4 avoids Postgres connection issues:
# DATABASE_HOST=127.0.0.1
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres

# --- Optional: local production-like checks ---
# SECRET_KEY_BASE=""

# --- Optional: seeds on production ---
# If set to true in production, demo attendee rows may be created (normally off).
# SEED_SAMPLE_DATA=""
